# ── Required ──────────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins (no spaces)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# HuggingFace model ID for deepfake classification
MODEL_NAME=prithivMLmods/Deep-Fake-Detector-Model

# Max video frames to sample (1 FPS up to this limit)
MAX_VIDEO_FRAMES=30

# ── Optional ──────────────────────────────────────────────────────────────────
# SQLite DB path (default: ./truthlens.db — kept out of git)
# DATABASE_URL=sqlite:///./synthguard.db
